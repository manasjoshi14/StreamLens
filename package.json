{
  "name": "streamlens",
  "description": "Browser extension that overlays ratings on supported streaming platform titles",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:safari": "wxt -b safari",
    "build": "wxt build",
    "build:safari": "wxt build -b safari",
    "zip": "wxt zip",
    "zip:safari": "wxt zip -b safari",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "wxt": "^0.20.18"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "spawn-sync"
    ]
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
